#!/usr/bin/env node

/**
 * Vertex standalone CLI runtime.
 *
 * This executes the vendored CLI bundle directly so the `vertex` command does
 * not depend on an external CLI binary being installed on PATH.
 */

import { existsSync } from 'fs'
import { join, dirname } from 'path'
import { fileURLToPath, pathToFileURL } from 'url'

const __dirname = dirname(fileURLToPath(import.meta.url))
const distPath = join(__dirname, '..', 'dist', 'cli.mjs')

if (existsSync(distPath)) {
  await import(pathToFileURL(distPath).href)
} else {
  console.error(`
  vertex: dist/cli.mjs not found.

  Reinstall Vertex or rebuild the vendored CLI runtime.
`)
  process.exit(1)
}
